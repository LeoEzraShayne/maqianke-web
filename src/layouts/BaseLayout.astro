---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  current?: 'measure' | 'history' | 'about';
}

const { title, description, current } = Astro.props;
const apiBase = import.meta.env.PUBLIC_API_BASE_URL ?? 'https://maqianke-api.meritledger.org';
const returnTo = `${Astro.url.pathname}${Astro.url.search}`;
const loginUrl = `/login?returnTo=${encodeURIComponent(returnTo)}`;
const ogUrl = new URL('/og.png', Astro.url.origin).toString();
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f1eadc" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogUrl} />
    <title>{title}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <a class="brand" href="/" aria-label="马前课首页">
          <img src="/images/maqianke-logo.png" width="600" height="288" alt="马前课，决策之王" />
        </a>
        <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="site-nav">菜单</button>
        <div class="header-actions" id="site-nav">
          <nav aria-label="主导航">
            <a class:list={{ active: current === 'measure' }} href="/">测算</a>
            <a class:list={{ active: current === 'history' }} href="/history">历史记录</a>
            <a class:list={{ active: current === 'about' }} href="/about">关于</a>
          </nav>
          <div class="auth-actions">
            <a class="local-login" id="local-login" href={loginUrl}>
              <span class="account-mark" aria-hidden="true">入</span>
              <span>登录 / 注册</span>
            </a>
            <a class="account-link signed-in" id="account-link" href="/history" hidden>
              <span class="account-mark" id="auth-mark" aria-hidden="true">我</span>
              <span id="auth-label">我的课簿</span>
            </a>
            <button class="logout-button" id="logout-button" type="button" hidden>退出</button>
          </div>
        </div>
      </header>
      <main><slot /></main>
      <footer class="site-footer">
        <span>© 2026 马前课</span>
        <span class="footer-flourish" aria-hidden="true">◆</span>
        <a href="/terms">用户协议</a>
        <a href="/privacy">隐私政策</a>
        <a href="/about">关于马前课</a>
      </footer>
    </div>
    <script is:inline define:vars={{ apiBase }}>
      const toggle = document.querySelector('.nav-toggle');
      const nav = document.querySelector('#site-nav');
      toggle?.addEventListener('click', () => {
        const open = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!open));
        nav?.classList.toggle('is-open', !open);
      });

      const loginLink = document.querySelector('#local-login');
      const accountLink = document.querySelector('#account-link');
      const authLabel = document.querySelector('#auth-label');
      const authMark = document.querySelector('#auth-mark');
      const logoutButton = document.querySelector('#logout-button');
      async function loadCurrentUser() {
        try {
          const response = await fetch(`${apiBase}/api/me`, { credentials: 'include' });
          if (!response.ok) return null;
          const { user } = await response.json();
          authLabel.textContent = user.name || user.email;
          authMark.textContent = (user.name || user.email || '我').trim().slice(0, 1);
          loginLink.hidden = true;
          accountLink.hidden = false;
          logoutButton.hidden = false;
          document.documentElement.dataset.authenticated = 'true';
          window.dispatchEvent(new CustomEvent('maqianke:auth', { detail: user }));
          return user;
        } catch {
          return null;
        }
      }
      window.maqiankeAuth = { apiBase, loadCurrentUser, userPromise: loadCurrentUser() };

      logoutButton?.addEventListener('click', async () => {
        logoutButton.disabled = true;
        try {
          await fetch(`${apiBase}/api/logout`, { method: 'POST', credentials: 'include' });
        } finally {
          window.location.href = '/';
        }
      });

      const loginStatus = new URL(window.location.href).searchParams.get('login');
      if (loginStatus) {
        window.history.replaceState({}, '', `${window.location.pathname}${window.location.hash}`);
      }
    </script>
  </body>
</html>
